#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

cmd="${1:-run}"

case "$cmd" in
  auto|autonomous|continuous)
    shift || true
    exec mix osa.roberto.codex --continuous "$@"
    ;;
  run|codex)
    shift || true
    exec mix osa.roberto.codex "$@"
    ;;
  once)
    shift || true
    exec mix osa.roberto.codex "$@"
    ;;
  resume)
    shift || true
    exec mix osa.roberto.resume "$@"
    ;;
  prompt)
    shift || true
    exec mix osa.roberto.codex --prompt-only "$@"
    ;;
  help|-h|--help)
    cat <<'EOF'
Usage:
  scripts/roberto-loop auto       # keep launching Roberto Codex slices until blocked
  scripts/roberto-loop            # launch one Roberto Codex slice
  scripts/roberto-loop once       # explicit one-slice alias
  scripts/roberto-loop resume     # print the current Roberto resume summary
  scripts/roberto-loop prompt     # print the generated Codex prompt

All other arguments are forwarded to the corresponding Mix task.
Useful autonomous flags:
  --idle-timeout-seconds N        # restart / stop if a Codex slice stops emitting for N seconds
  --max-idle-retries N            # cap automatic restarts after idle timeouts
EOF
    ;;
  *)
    exec mix osa.roberto.codex "$@"
    ;;
esac
